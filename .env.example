API_KEY=your_secret_key_here

# Upstash Redis — get from upstash.com (free tier, Singapore region)
# Used for session state. Leave blank to use in-memory fallback locally.
REDIS_URL=your_upstash_redis_url_here

# MongoDB Atlas — get from cloud.mongodb.com (free tier, Mumbai region)
# Used for conversation logs. Leave blank to skip logging locally.
MONGO_URL=your_mongodb_connection_string_here
MONGO_DB_NAME=varta_logs
